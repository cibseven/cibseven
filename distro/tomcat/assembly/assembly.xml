  xmlns="urn:maven:assembly:1.1.0-SNAPSHOT">
    
  <id>assemble</id>
    
  <formats>
    <format>tar.gz</format>
  </formats>

  <includeBaseDirectory>false</includeBaseDirectory>

  <dependencySets>
   <dependencySet>
