  <profiles>
    <profile>
      <id>wildfly</id>
      <properties>
        <jboss.runtime>${basedir}/../${wildfly.runtime.location}</jboss.runtime>
        <http.port>${jboss.http.port}</http.port>
      </properties>
      <dependencies>
        <dependency>
          <!-- make sure it comes after assembly in the build -->
          <groupId>org.cibseven.bpm.qa</groupId>
          <artifactId>cibseven-qa-wildfly-runtime</artifactId>
          <version>${project.version}</version>
          <type>pom</type>
        </dependency>
        <dependency>
          <groupId>org.cibseven.bpm.webapp</groupId>
          <artifactId>cibseven-webapp-wildfly</artifactId>
          <version>${project.version}</version>
          <type>war</type>
          <scope>test</scope>
        </dependency>
        <dependency>
          <groupId>org.cibseven.bpm</groupId>
          <artifactId>cibseven-engine-rest</artifactId>
          <version>${project.version}</version>
          <classifier>wildfly</classifier>
          <scope>test</scope>
          <type>war</type>
        </dependency>
        <dependency>
          <groupId>org.cibseven.bpm.example</groupId>
          <artifactId>cibseven-example-invoice</artifactId>
          <version>${project.version}</version>
          <scope>test</scope>
          <type>war</type>
        </dependency>
      </dependencies>
      <build>
        <plugins>
          <plugin>
            <groupId>org.codehaus.cargo</groupId>
            <artifactId>cargo-maven3-plugin</artifactId>
            <executions>
              <execution>
                <id>start-container</id>
                <phase>pre-integration-test</phase>
                <goals>
                  <goal>start</goal>
                </goals>
              </execution>
              <execution>
                <id>stop-container</id>
                <phase>post-integration-test</phase>
                <goals>
                  <goal>stop</goal>
                </goals>
              </execution>
            </executions>
            <configuration>
              <!-- verbose cargo logging so the log/output files below are actually written with useful detail
              <logLevel>high</logLevel>
	      <log>${project.build.directory}/wildfly-cargo.log</log>-->
              <!-- Container configuration -->
              <container>
                <type>installed</type>
                <containerId>${cargo.wildfly.container.id}</containerId>
                <append>false</append>
                <home>${jboss.runtime}</home>
                <timeout>${cargo.timeout}</timeout>
                <!-- capture WildFly server console output and cargo lifecycle logs for diagnostics
                <output>${project.build.directory}/wildfly-server.log</output>
		<log>${project.build.directory}/wildfly-cargo.log</log> -->
              </container>
              <configuration>
                <!-- IMPORTANT: use an *existing* configuration instead of letting Cargo generate a
                     'standalone' one.

                     Cargo 1.10.20 builds a standalone configuration by running an offline JBoss CLI
                     that boots an embedded WildFly server. That CLI runs with a HARDCODED,
                     non-configurable 60s JvmLauncher timeout (DefaultJvmLauncher.timeout = 60000,
                     and AbstractWildFlyInstalledLocalContainer.executeScriptFiles() never calls
                     setTimeout()). With WildFly 40 the embedded boot alone takes ~20-25s, so on
                     slower machines the CLI exceeds 60s and the container start fails - regardless
                     of the container <timeout> or any property.

                     The cibseven-qa-wildfly-runtime already ships a fully configured standalone.xml
                     (CIB seven engine, datasource, job executor, http=${jboss.http.port} /
                     ajp=${jboss.ajp.port}). By pointing Cargo at that existing server directory we
                     skip the offline CLI entirely; Cargo only deploys the WARs and starts the
                     server normally, which is governed by the container <timeout> (${cargo.timeout}). -->
                <type>existing</type>
                <home>${jboss.runtime}/standalone</home>
                <properties>
                  <!-- Cargo starts the server JVM directly via jboss-modules.jar, bypassing
                       WildFly's standalone.bat/standalone.sh launch scripts. Those scripts normally
                       set DEFAULT_MODULAR_JVM_OPTIONS (a set of add-opens/add-exports options
                       required on JDK 17+). Without them, WildFly 40's Infinispan protostream
                       marshaller fails with "module java.base does not open java.util to unnamed
                       module" (EnumMapMarshaller), breaking the 'web' and 'sfsb' cache-containers.
                       We therefore replicate the full DEFAULT_MODULAR_JVM_OPTIONS set here. -->
                  <cargo.jvmargs>-Djava.net.preferIPv4Stack=true --add-exports=java.desktop/sun.awt=ALL-UNNAMED --add-exports=java.naming/com.sun.jndi.ldap=ALL-UNNAMED --add-exports=java.naming/com.sun.jndi.url.ldap=ALL-UNNAMED --add-exports=java.naming/com.sun.jndi.url.ldaps=ALL-UNNAMED --add-exports=jdk.naming.dns/com.sun.jndi.dns=ALL-UNNAMED --add-opens=java.base/java.lang=ALL-UNNAMED --add-opens=java.base/java.lang.invoke=ALL-UNNAMED --add-opens=java.base/java.lang.reflect=ALL-UNNAMED --add-opens=java.base/java.io=ALL-UNNAMED --add-opens=java.base/java.net=ALL-UNNAMED --add-opens=java.base/java.security=ALL-UNNAMED --add-opens=java.base/java.util=ALL-UNNAMED --add-opens=java.base/java.util.concurrent=ALL-UNNAMED --add-opens=java.management/javax.management=ALL-UNNAMED --add-opens=java.naming/javax.naming=ALL-UNNAMED</cargo.jvmargs>
                  <!-- The runtime's standalone.xml binds the management interface on port 39990
                       (not Cargo's default 9990). Cargo's WildFly CombinedContainerMonitor polls
                       the management-http port to detect that the server is up; if it polls the
                       wrong port it never detects the running container and fails after the full
                       container <timeout> even though the server started fine. Point it at 39990. -->
                  <cargo.jboss.management-http.port>39990</cargo.jboss.management-http.port>
                  <cargo.servlet.port>${jboss.http.port}</cargo.servlet.port>
                </properties>
              </configuration>
              <deployables>
                <deployable>
                  <groupId>org.cibseven.bpm.example</groupId>
                  <artifactId>cibseven-example-invoice</artifactId>
                  <type>war</type>
                  <pingURL>http://localhost:${jboss.http.port}/engine-rest/engine/default/user/demo/profile</pingURL>
                  <pingTimeout>${cargo.deploy.timeout}</pingTimeout>
                </deployable>
                <deployable>
                  <groupId>org.cibseven.bpm</groupId>
                  <artifactId>cibseven-engine-rest</artifactId>
                  <classifier>wildfly</classifier>
                  <type>war</type>
                  <pingURL>http://localhost:${jboss.http.port}/engine-rest/engine/default/process-definition</pingURL>
                  <pingTimeout>${cargo.deploy.timeout}</pingTimeout>
                </deployable>
                <deployable>
                  <groupId>org.cibseven.bpm.webapp</groupId>
                  <artifactId>cibseven-webapp-wildfly</artifactId>
                  <type>war</type>
                  <pingURL>http://localhost:${jboss.http.port}/camunda</pingURL>
                  <pingTimeout>${cargo.deploy.timeout}</pingTimeout>
                </deployable>
              </deployables>
            </configuration>
          </plugin>
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-failsafe-plugin</artifactId>
            <configuration>
              <excludes>
                <!-- CAM-14109 -->
                <exclude>**/SessionCookieSameSiteIT.java</exclude>
                <exclude>**/LoginIT.java</exclude>
              </excludes>
            </configuration>
          </plugin>
        </plugins>
      </build>
    </profile>
    
