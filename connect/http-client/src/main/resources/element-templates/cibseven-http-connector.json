{
  "$schema": "https://unpkg.com/@camunda/element-templates-json-schema/resources/schema.json",
  "name": "CIB seven - HTTP Connector",
  "id": "org.cibseven.connect.httpclient",
  "version": 1,
  "description": "Make an HTTP(S) request from a Service Task via the CIB seven HTTP connector (connectorId: http-connector).",
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  },
  "keywords": [
    "http",
    "https",
    "rest",
    "connector",
    "request"
  ],
  "appliesTo": [
    "bpmn:ServiceTask"
  ],
  "groups": [
    {
      "id": "request",
      "label": "HTTP request"
    },
    {
      "id": "config",
      "label": "Request configuration"
    },
    {
      "id": "output",
      "label": "Response mapping"
    }
  ],
  "scopes": [
    {
      "type": "camunda:Connector",
      "properties": [
        {
          "type": "Hidden",
          "value": "http-connector",
          "binding": {
            "type": "property",
            "name": "connectorId"
          }
        },
        {
          "label": "Method",
          "group": "request",
          "type": "Dropdown",
          "value": "GET",
          "choices": [
            { "name": "GET", "value": "GET" },
            { "name": "POST", "value": "POST" },
            { "name": "PUT", "value": "PUT" },
            { "name": "PATCH", "value": "PATCH" },
            { "name": "DELETE", "value": "DELETE" },
            { "name": "HEAD", "value": "HEAD" },
            { "name": "OPTIONS", "value": "OPTIONS" },
            { "name": "TRACE", "value": "TRACE" }
          ],
          "binding": {
            "type": "camunda:inputParameter",
            "name": "method"
          }
        },
        {
          "label": "URL",
          "group": "request",
          "description": "Absolute target URL, e.g. https://api.example.com/v1/orders. Expressions are allowed, e.g. ${baseUrl}/orders.",
          "type": "String",
          "feel": "optional",
          "binding": {
            "type": "camunda:inputParameter",
            "name": "url"
          },
          "constraints": {
            "notEmpty": true
          }
        },
        {
          "label": "Headers (map)",
          "group": "request",
          "description": "Expression resolving to a Map<String,String>, e.g. ${ {\"Content-Type\":\"application/json\",\"Authorization\":\"Bearer \"+token} }. Leave empty if not needed.",
          "type": "Text",
          "feel": "optional",
          "optional": true,
          "binding": {
            "type": "camunda:inputParameter",
            "name": "headers"
          }
        },
        {
          "label": "Payload (body)",
          "group": "request",
          "description": "Request body for POST/PUT/PATCH. A String or an expression, e.g. ${orderJson}.",
          "type": "Text",
          "feel": "optional",
          "optional": true,
          "binding": {
            "type": "camunda:inputParameter",
            "name": "payload"
          }
        },
        {
          "label": "Request config (map)",
          "group": "config",
          "description": "Optional expression resolving to a Map of request-config options, e.g. ${ {\"connection-timeout\":5000,\"response-timeout\":10000,\"redirects-enabled\":true} }. Supported keys: authentication-enabled, circular-redirects-allowed, connection-timeout, connection-keep-alive, connection-request-timeout, content-compression-enabled, cookie-spec, expect-continue-enabled, hard-cancellation-enabled, max-redirects, proxy, proxy-preferred-auth-scheme, redirects-enabled, response-timeout, target-preferred-auth-schemes.",
          "type": "Text",
          "feel": "optional",
          "optional": true,
          "binding": {
            "type": "camunda:inputParameter",
            "name": "request-config"
          }
        },
        {
          "label": "Status code -> variable",
          "group": "output",
          "description": "Process variable that receives the HTTP status code.",
          "type": "String",
          "value": "statusCode",
          "binding": {
            "type": "camunda:outputParameter",
            "source": "${statusCode}"
          }
        },
        {
          "label": "Response body -> variable",
          "group": "output",
          "description": "Process variable that receives the response body.",
          "type": "String",
          "value": "response",
          "binding": {
            "type": "camunda:outputParameter",
            "source": "${response}"
          }
        },
        {
          "label": "Response headers -> variable",
          "group": "output",
          "description": "Optional. Process variable that receives the response headers map. Leave empty to skip.",
          "type": "String",
          "optional": true,
          "binding": {
            "type": "camunda:outputParameter",
            "source": "${headers}"
          }
        }
      ]
    }
  ]
}
